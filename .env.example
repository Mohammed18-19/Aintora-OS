# ═══════════════════════════════════════════════════════════════════════════════
# AINTORA SYSTEMS — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME="AINTORA SYSTEMS"
APP_VERSION="1.0.0"
DEBUG=false

# CRITICAL: Change this to a random 32+ character string in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_super_secret_key_change_this_immediately_32chars_min

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=aintora_db
POSTGRES_USER=aintora
POSTGRES_PASSWORD=aintora_pass_change_me

# These are constructed from the above in docker-compose.yml
# Only set manually if running outside Docker:
# DATABASE_URL=postgresql+asyncpg://aintora:aintora_pass@localhost:5432/aintora_db
# DATABASE_URL_SYNC=postgresql://aintora:aintora_pass@localhost:5432/aintora_db

# ─── WhatsApp Meta Cloud API ──────────────────────────────────────────────────
# Get these from: https://developers.facebook.com → Your App → WhatsApp → API Setup

# Global verify token for webhook verification
META_VERIFY_TOKEN=aintora_verify_token_change_me

# App Secret (from App Settings → Basic → App Secret)
# Used for webhook signature verification
META_APP_SECRET=your_meta_app_secret_here

# Per-tenant tokens are stored in the database.
# These are only fallback defaults (optional):
DEFAULT_WHATSAPP_PHONE_ID=
DEFAULT_WHATSAPP_TOKEN=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list - NO spaces between URLs
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://app.aintora.com

# ─── Super Admin (Platform Owner = YOU) ──────────────────────────────────────
# CHANGE THESE before first deployment!
SUPER_ADMIN_EMAIL=admin@aintora.com
SUPER_ADMIN_PASSWORD=change_me_immediately_admin_2024!

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Set to DEBUG for development, INFO for staging, WARNING for production
